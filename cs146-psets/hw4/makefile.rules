#
# Pin build settings for the hw4 cache simulator tool.
#
# Pin's default rules compile one shared object per entry in TEST_TOOL_ROOTS.
# Setting it to "hw4" causes Pin's makefile to compile hw4.cpp and link it
# into obj-intel64/hw4.so (the path the run script expects).
#

TEST_TOOL_ROOTS := hw4

# The remaining variables are unused for this single-tool build.
TEST_ROOTS      :=
TOOL_ROOTS      :=
SA_TOOL_ROOTS   :=
APP_ROOTS       :=
OBJECT_ROOTS    :=
DLL_ROOTS       :=
LIB_ROOTS       :=
